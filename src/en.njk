---
layout: layout.njk
lang: en
permalink: /
---
{% set entries = resolvedEntries.en %}
<header>
  <nav class="lang-toggle" aria-label="Language">
    <span class="lang-current" aria-current="page">EN</span><span class="lang-sep" aria-hidden="true">/</span><a href="/de/" lang="de" hreflang="de">DE</a>
  </nav>
  <div class="kicker">{{ i18n.kicker }}</div>
  <h1>{{ i18n.title }}</h1>
  <p class="standfirst">{{ i18n.tagline }}</p>
  <div class="meta">
    Every claim links to a court filing, government report, or primary investigation.<br>
    No anonymous allegations. Read the sources. Verify everything.
  </div>
  <p class="ledger-updated">{{ i18n.ledgerUpdated }} {{ buildDate }}</p>
  <nav class="quick-nav">
    <a href="#sources">About</a>
    <a href="#contact">{{ i18n.suggestEntry }}</a>
    <a href="#footer">Author</a>
  </nav>
</header>

<div class="filters" id="filters">
  <div class="filter-bar">
    <!-- Row 1: view toggle (js-only) -->
    <div class="filter-row filter-row-views js-only">
      <div class="view-toggle" role="group" aria-label="View mode">
        <button type="button" id="view-narrative" class="view-btn" aria-pressed="true">{{ i18n.viewNarrative }}</button>
        <button type="button" id="view-recent" class="view-btn" aria-pressed="false">{{ i18n.viewRecent }}</button>
        <button type="button" id="view-timeline" class="view-btn" aria-pressed="false">{{ i18n.viewTimeline }}</button>
      </div>
    </div>
    <!-- Row 2: search input full width (js-only) -->
    <div class="filter-row filter-row-search js-only">
      <label for="search-input" class="sr-only">{{ i18n.searchPlaceholder }}</label>
      <div class="search-wrap">
        <input type="search" id="search-input" class="search-input"
          placeholder="{{ i18n.searchPlaceholder }}" autocomplete="off"
          aria-label="{{ i18n.searchPlaceholder }}" spellcheck="false">
        <button type="button" id="search-clear" class="search-clear" aria-label="Clear search" hidden>✕</button>
      </div>
    </div>
    <!-- Row 3: controls left + status right (always visible) -->
    <div class="filter-row filter-row-controls">
      <div class="filter-controls-left">
        <button class="filter-toggle" id="filter-toggle" aria-expanded="false" aria-controls="filter-body">
          <span class="filter-toggle-label">{{ i18n.filterToggle }}</span>
          <span class="filter-toggle-arrow" aria-hidden="true">▾</span>
        </button>
        <button type="button" id="expand-all" class="expand-all-btn js-only" aria-label="{{ i18n.collapseAll }}">{{ i18n.collapseAll }}</button>
      </div>
      <span class="filter-meta">
        <span id="result-count" aria-live="polite" aria-atomic="true"></span><span id="active-hint"></span> · <a href="#" id="clear-filters">{{ i18n.clearAll }}</a>
      </span>
    </div>
  </div>
  <div class="filter-body" id="filter-body" hidden>
    <div class="filter-group">
      <span class="filter-label">{{ i18n.filterTopic }}</span>
      {% for s in site.sections %}
      <button class="chip" data-filter="section" data-value="{{ s.key }}">{{ i18n.sections[s.key] }}</button>
      {% endfor %}
    </div>
    <div class="filter-group">
      <span class="filter-label">{{ i18n.filterRegion }}</span>
      {% for r in site.regions %}
      <button class="chip" data-filter="region" data-value="{{ r.key }}">{{ i18n.regions[r.key] }}</button>
      {% endfor %}
    </div>
    <div class="filter-group">
      <span class="filter-label">{{ i18n.filterStatus }}</span>
      {% for st in site.statuses %}
      <button class="chip" data-filter="status" data-value="{{ st.key }}">{{ i18n.statuses[st.key] }}</button>
      {% endfor %}
    </div>
  </div>
</div>

{% for s in site.sections %}
<section id="{{ s.key }}" data-section-block="{{ s.key }}" data-section-label="{{ i18n.sections[s.key] }}">
  <div class="sec-head" role="button" tabindex="0"
    aria-expanded="true" aria-controls="sec-content-{{ s.key }}"
    data-sec-toggle>
    <span class="sec-num">{{ s.num }}</span>
    <h2>{{ i18n.sections[s.key] }}</h2>
    <span class="sec-caret" aria-hidden="true">▾</span>
  </div>
  <div class="sec-content" id="sec-content-{{ s.key }}">
    {% if i18n.sectionIntros[s.key] %}
    <p class="sec-sub">{{ i18n.sectionIntros[s.key] }}</p>
    {% endif %}
    {%- set count = 0 -%}
    {% for entry in entries %}
      {%- if entry.section == s.key -%}
        {%- set count = count + 1 -%}
        <article class="entry"
          id="entry-{{ entry.slug }}"
          data-slug="{{ entry.slug }}"
          data-section="{{ entry.section }}"
          data-region="{{ entry.region }}"
          data-status="{{ entry.status }}"
          data-year="{{ entry.date | year }}"
          data-date="{{ entry.date }}"
          data-added="{{ entry.added }}">
          {% if not entry.translated %}
          <div class="translation-note">{{ i18n.translationNote }}</div>
          {% endif %}
          <h3>
            {% if entry.tag %}<span class="tag">{{ entry.tag }}</span>{% endif %}
            {{ entry.title }}
          </h3>
          <div class="body">{{ entry.bodyBlocks | renderBlocks | safe }}</div>
          {% if entry.sources and entry.sources.length %}
          <div class="sources">
            {% for src in entry.sources %}
            <span class="src"><span class="label{% if src.video %} vid{% endif %}">{% if src.video %}{{ i18n.video }}{% else %}{{ i18n.src }}{% endif %}</span><a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.label }}</a>{% if src.archive_url %} <span class="src-sep">·</span> <a class="archive-link" href="{{ src.archive_url }}" target="_blank" rel="noopener" title="Permanent snapshot — Wayback Machine">{{ i18n.archived }}</a>{% endif %}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if entry.last_verified %}<div class="verified">{{ i18n.lastVerified }} {{ entry.last_verified }}</div>{% endif %}
          <span class="entry-actions js-only" data-slug="{{ entry.slug }}" data-title="{{ entry.title }}" data-entry-url="/entry/{{ entry.slug }}/" data-portrait="/cards/en/{{ entry.slug }}-portrait.png">
            <button type="button" class="act-send" hidden>{{ i18n.shareLabel }}</button>
            <span class="act-card">
              <a download="ontherecord-{{ entry.slug }}-portrait.png" href="/cards/en/{{ entry.slug }}-portrait.png">{{ i18n.cardPortrait }}</a>
              <a download="ontherecord-{{ entry.slug }}-wide.png" href="/cards/en/{{ entry.slug }}-og.png">{{ i18n.cardWide }}</a>
            </span>
            <a class="act-copy" href="/entry/{{ entry.slug }}/" data-copied-label="{{ i18n.copied }}">{{ i18n.copyLink }}</a>
          </span>
        </article>
      {%- endif -%}
    {% endfor %}
    {% if count == 0 %}<p class="sec-empty">{{ i18n.sectionEmpty }}</p>{% endif %}
    {% if i18n.pullquotes[s.key] %}
    <p class="pullquote">{{ i18n.pullquotes[s.key] }}</p>
    {% endif %}
  </div>
</section>
{% endfor %}

<section id="sources">
  <div class="sec-head">
    <span class="sec-num">§</span>
    <h2>{{ i18n.howToUseThis }}</h2>
  </div>
  <p class="sec-sub">A ledger is only as good as its sources.</p>
  <p class="spirit-note">{{ i18n.spiritNote }}</p>
  <div class="entry">
    <p>Every entry above links to a court filing, a government report, an investigative outlet, or a primary document archive. Don't take this page's word for anything — follow the links and read the originals. Where a claim rests on a lawsuit, that means it is an allegation being tested in court, not a proven fact; where it rests on a guilty plea, settlement admission, or NLRB ruling, it has been adjudicated. The distinction matters. Use it.</p>
    <p><strong style="font-family:'JetBrains Mono',monospace;font-size:14px;">For deeper digging:</strong></p>
    <div class="sources">
      {% for link in site.deepDig %}
      <span class="src"><span class="label">{{ link.label }}</span><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.name }}</a></span>
      {% endfor %}
    </div>
    <p class="form-note">{{ i18n.cookieNote }}</p>
  </div>
</section>

<section class="contact" id="contact">
  <div class="sec-head">
    <span class="sec-num">+</span>
    <h2>{{ i18n.suggestEntry }}</h2>
  </div>
  <p class="sec-sub">Know a documented case that belongs here? Send it — anonymously if you like. Include a primary source if you have one.</p>

  {% if site.web3formsKey %}
  <form id="suggest-form" action="https://api.web3forms.com/submit" method="POST">
    <input type="hidden" name="access_key" value="{{ site.web3formsKey }}">
    <input type="hidden" name="subject" value="On The Record — new entry suggestion">
    <input type="hidden" name="from_name" value="On The Record site">
    <!-- Honeypot: hidden from humans, bots fill it, Web3Forms drops it. -->
    <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off">

    <label for="topic">Topic / who</label>
    <input type="text" id="topic" name="topic" placeholder="e.g. Company X, Politician Y">

    <label for="message">What happened &amp; why it belongs</label>
    <textarea id="message" name="message" required placeholder="Describe the case…"></textarea>

    <label for="source">Primary source link (optional)</label>
    <input type="url" id="source" name="source" placeholder="https://…">

    <label for="contact_back">Contact back (optional — leave blank to stay anonymous)</label>
    <input type="email" id="contact_back" name="contact_back" placeholder="you@example.com">

    {% if site.turnstileSiteKey %}
    <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey }}" style="margin-top:16px;"></div>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    {% endif %}

    <button type="submit" id="submit-btn">{{ i18n.contactSubmit }}</button>
    <div id="form-status"></div>
  </form>
  <p class="form-note">
    Submissions go to the maintainer's inbox via Web3Forms. No tracking, no account required.
    A hidden anti-bot field protects against spam.
  </p>
  {% else %}
  <p class="form-note">
    The suggestion form isn't active yet. To enable it: get a free key at web3forms.com
    (just enter an email — no account), paste it into <code>src/_data/site.js</code> as
    <code>web3formsKey</code>, and rebuild. Until then, suggestions can be sent by whatever
    channel the maintainer prefers.
  </p>
  {% endif %}
</section>

<footer id="footer">
  <strong>{{ i18n.title | upper }}</strong> — an open ledger of documented corporate &amp; political harm.<br>
  Compiled from public court filings, government reports and investigative journalism.
  <div class="disclaim">
    This page documents wrongdoing and points to evidence. It is a tool for accountability through
    information, organizing and the law — not a call for harm against any person. {{ i18n.disclaimer }}
  </div>
  Verify everything. Cite your sources. Share freely.
</footer>
