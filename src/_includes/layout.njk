<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{#- Per-page overrides (entry pages set these); defaults keep the list pages intact. -#}
{%- set metaTitle = pageTitle or (i18n.title ~ " — " ~ i18n.titleSuffix) -%}
{%- set metaDescription = pageDescription or i18n.tagline -%}
{%- set ogImageAbs = ogImageUrl or (site.url ~ site.ogImage) -%}
{%- set altEn = hreflangEn or (site.url ~ "/") -%}
{%- set altDe = hreflangDe or (site.url ~ "/de/") -%}
{%- set altDefault = hreflangXDefault or (site.url ~ "/") -%}
<title>{{ metaTitle }}</title>
<meta name="description" content="{{ metaDescription }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- OpenGraph -->
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ metaTitle }}">
<meta property="og:description" content="{{ metaDescription }}">
{% if ogImageAbs %}<meta property="og:image" content="{{ ogImageAbs }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">{% endif %}
<meta property="og:locale" content="{{ i18n.ogLocale }}">
<meta property="og:site_name" content="{{ i18n.title }}">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ metaTitle }}">
<meta name="twitter:description" content="{{ metaDescription }}">
{% if ogImageAbs %}<meta name="twitter:image" content="{{ ogImageAbs }}">{% endif %}

<!-- Indexing -->
<meta name="robots" content="index, follow">

<!-- hreflang alternates — en and de are alternates of each other; each page
     canonicalizes to ITSELF (see canonical above). x-default points at en. On
     entry pages these resolve to the en/de twins of that single entry. -->
<link rel="alternate" hreflang="en" href="{{ altEn }}">
<link rel="alternate" hreflang="de" href="{{ altDe }}">
<link rel="alternate" hreflang="x-default" href="{{ altDefault }}">

<style>
  /* Self-hosted fonts — no third-party requests, no visitor IP leakage. */
  @font-face {
    font-family: 'JetBrains Mono'; font-weight: 400 800; font-display: swap;
    src: url('/assets/fonts/jetbrains-mono.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Newsreader'; font-weight: 400 500; font-display: swap;
    src: url('/assets/fonts/newsreader.woff2') format('woff2');
  }
</style>
<link rel="icon" type="image/png" href="/assets/favicon.png">
<link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
<link rel="stylesheet" href="/assets/style.css?v={{ assetVersion }}">
<script>
  document.documentElement.classList.remove('no-js');
  document.documentElement.classList.add('js');
</script>
{# Entry pages are static destinations — no filter/search/view JS. #}
{% if not entryPage %}<script src="/assets/filter.js?v={{ assetVersion }}" defer></script>{% endif %}
</head>
<body class="no-js">

<div class="wrap">
{{ content | safe }}
</div>

{% if not entryPage %}<script>
  window.__SEARCH_INDEX__ = {{ searchIndex[lang] | safe }};
</script>{% endif %}

</body>
</html>
